<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.supergaos.seckill.mapper.SeckillActivityMapper">
    <resultMap id="baseMap" type="SeckillActivity">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="price" property="price"/>
        <result column="stock" property="stock"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findAll" resultMap="baseMap">
        SELECT * FROM seckill_activity ORDER BY start_time DESC
    </select>

    <select id="findById" resultMap="baseMap">
        SELECT * FROM seckill_activity WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO seckill_activity (title, price, stock, start_time, end_time, status)
        VALUES (#{title}, #{price}, #{stock}, #{startTime}, #{endTime}, #{status})
    </insert>

    <update id="updateStock">
        UPDATE seckill_activity SET stock = stock + #{amount} WHERE id = #{id} AND stock + #{amount} >= 0
    </update>
</mapper>
